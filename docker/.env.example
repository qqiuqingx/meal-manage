# =============================================================================
# eladmin-mp Docker Environment Variables
# Copy this file to .env and fill in your values.
# IMPORTANT: .env contains secrets and must NEVER be committed to version control.
# =============================================================================

# ------------------------------
# Backend (Spring Boot)
# ------------------------------
# Spring profile: dev / prod
SPRING_PROFILES_ACTIVE=prod

# MySQL — 指向已有的生产数据库
DB_HOST=127.0.0.1
DB_PORT=13306
DB_NAME=mydatabase
DB_USER=root
DB_PWD=YourStrongPassword123

# Redis — 指向已有的生产 Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=16379
REDIS_DB=1
REDIS_PWD=YourStrongPassword123

# JWT — 生产环境请务必替换为新的随机密钥
# 生成方式: openssl rand -base64 128 | tr -d '\n'
JWT_BASE64_SECRET=REDACTED_JWT_SECRET

# JVM 堆内存设置
BACKEND_JVM_HEAP_MIN=256m
BACKEND_JVM_HEAP_MAX=512m

# ------------------------------
# Docker Image Tag
# ------------------------------
# 镜像 tag，由 deploy-from-github.sh 自动生成（格式：YYYYMMDDHHMM）
# 此处留空或设置默认值仅供本地参考，生产部署时由脚本覆盖
IMAGE_TAG=latest
