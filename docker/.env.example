# =============================================================================
# eladmin-mp Docker Environment Variables
# Copy this file to .env and fill in your values.
# IMPORTANT: .env contains secrets and must NEVER be committed to version control.
# =============================================================================

# ------------------------------
# Backend (Spring Boot)
# ------------------------------
# Spring profile: dev / prod
SPRING_PROFILES_ACTIVE=prod

# MySQL — 填写本地或私有环境数据库
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=eladmin
DB_USER=root
DB_PWD=change-me

# Redis — 填写本地或私有环境 Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=1
REDIS_PWD=change-me

# JWT — 公开仓库只保留占位符，实际值放到本地 .env
JWT_BASE64_SECRET=change-me
RSA_PRIVATE_KEY=change-me
LOGIN_CODE_DEV_BYPASS=

# JVM 堆内存设置
BACKEND_JVM_HEAP_MIN=256m
BACKEND_JVM_HEAP_MAX=512m

# ------------------------------
# Docker Image Tag
# ------------------------------
# 镜像 tag，由 deploy-from-github.sh 自动生成（格式：YYYYMMDDHHMM）
# 此处留空或设置默认值仅供本地参考，生产部署时由脚本覆盖
IMAGE_TAG=latest
