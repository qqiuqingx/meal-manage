<?xml version="1.0" encoding="UTF-8"?>
<configuration scan="true" scanPeriod="30 seconds" debug="false">
    <contextName>elAdmin</contextName>
    <property name="log.charset" value="utf-8" />
    <property name="log.pattern" value="%contextName- %red(%d{yyyy-MM-dd HH:mm:ss}) %green([%thread]) %highlight(%-5level) %boldMagenta(%logger{36}) - %msg%n" />

    <!-- 从 Spring 环境读取日志目录（dev: ./logs，prod: /app/logs） -->
    <springProperty scope="context" name="log.path" source="logging.path" defaultValue="./logs"/>

    <!-- 输出到控制台 -->
    <appender name="console" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${log.pattern}</pattern>
            <charset>${log.charset}</charset>
        </encoder>
    </appender>

    <!-- 排餐计划业务日志文件（每天一个文件，保留30天） -->
    <appender name="MEAL_PLAN_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${log.path}/meal-plan.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${log.path}/meal-plan.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>30</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} [%thread] %-5level %logger{36} - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- 核销服务日志文件（每天一个文件，保留30天） -->
    <appender name="MEAL_VERIFICATION_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${log.path}/meal-verification.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${log.path}/meal-verification.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>30</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} [%thread] %-5level %logger{36} - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- Agent 诊断调用日志文件（每天一个文件，保留30天） -->
    <appender name="AGENT_DIAGNOSIS_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${log.path}/agent-diagnosis.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${log.path}/agent-diagnosis.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>30</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} [%thread] %-5level requestId=%X{requestId} %logger{36} - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- 排餐计划服务日志单独写文件 -->
    <logger name="me.zhengjie.modules.meal.service.impl.MealPlanServiceImpl" level="info" additivity="false">
        <appender-ref ref="MEAL_PLAN_FILE" />
        <appender-ref ref="console" />
    </logger>

    <!-- 核销服务日志单独写文件 -->
    <logger name="me.zhengjie.modules.meal.service.impl.MealVerificationServiceImpl" level="info" additivity="false">
        <appender-ref ref="MEAL_VERIFICATION_FILE" />
        <appender-ref ref="console" />
    </logger>

    <!-- Agent 诊断日志单独写文件 -->
    <logger name="me.zhengjie.modules.agent" level="info" additivity="false">
        <appender-ref ref="AGENT_DIAGNOSIS_FILE" />
        <appender-ref ref="console" />
    </logger>

    <!-- 普通日志输出到控制台 -->
    <root level="info">
        <appender-ref ref="console" />
    </root>

    <!-- Spring 日志级别控制 -->
    <logger name="org.springframework" level="warn" />

    <!-- DnsServerAddressStreamProviders调整为ERROR -->
    <logger name="io.netty.resolver.dns.DnsServerAddressStreamProviders" level="ERROR"/>

    <!-- 设置其他类的日志级别为 ERROR -->
    <logger name="org.apache.catalina.core.ContainerBase.[Tomcat].[localhost].[/]" level="ERROR"/>
    <logger name="org.springframework.web.servlet.DispatcherServlet" level="ERROR"/>
</configuration>
