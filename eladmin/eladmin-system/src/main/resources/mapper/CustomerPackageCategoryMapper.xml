<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="me.zhengjie.modules.customer.profile.mapper.CustomerPackageCategoryMapper">

    <resultMap id="BaseResultMap" type="me.zhengjie.modules.customer.profile.domain.CustomerPackageCategory">
        <id column="id" property="id"/>
        <result column="category_name" property="categoryName"/>
        <result column="category_code" property="categoryCode"/>
        <result column="parent_id" property="parentId"/>
        <result column="level" property="level"/>
        <result column="sort" property="sort"/>
        <result column="enabled" property="enabled"/>
        <result column="code_prefix" property="codePrefix"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <!-- 查询所有分类(按sort排序) -->
    <select id="findAllOrderBySort" resultMap="BaseResultMap">
        SELECT * FROM customer_package_category
        ORDER BY sort ASC
    </select>

    <!-- 查询启用状态的父级分类 -->
    <select id="findEnabledParents" resultMap="BaseResultMap">
        SELECT * FROM customer_package_category
        WHERE level = 1 AND enabled = 1
        ORDER BY sort ASC
    </select>

    <!-- 检查是否存在指定前缀的启用父级 -->
    <select id="existsEnabledParentPrefix" resultType="boolean">
        SELECT EXISTS(
            SELECT 1 FROM customer_package_category
            WHERE code_prefix = #{codePrefix}
              AND level = 1
              AND enabled = 1
              <if test="excludeId != null">
                  AND id != #{excludeId}
              </if>
        )
    </select>

    <!-- 统计子级数量 -->
    <select id="countChildren" resultType="int">
        SELECT COUNT(*) FROM customer_package_category
        WHERE parent_id = #{parentId}
    </select>

    <!-- 统计客户引用数量 -->
    <select id="countCustomerReferences" resultType="int">
        SELECT COUNT(*) FROM customer_profile_package
        WHERE parent_package_id = #{categoryId}
           OR child_package_id = #{categoryId}
    </select>

</mapper>