<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="me.zhengjie.modules.customer.numberpool.mapper.NumberPoolMapper">

    <!--
        查询 [pool_start, pool_end] 范围内已被占用的编号.

        释放机制（被动式）— POOL-09, POOL-10, POOL-11:

        当 customer_order.status 从 1（进行中）变为 0（已取消）或 2（已完成）时，
        该客户的编号会自动从结果集中排除，无需任何显式"释放"操作。

        这是 POOL-09（自动释放）、POOL-10（分配和释放在不同事务）、
        POOL-11（只排除有进行中订单的编号）的实现。

        流程示意：
        1. allocate() 调用 findUsedCodesInRange()，仅返回 status=1 的客户编号
        2. 用户取消/完成订单，UPDATE customer_order SET status=0/2（独立事务）
        3. 下一次 allocate() 调用 findUsedCodesInRange()，该编号已不在结果集中
        4. allocate() 将其分配给新的客户档案

        无需 CustomerOrderServiceImpl 调用任何 release() 方法。

        技术细节：
        INNER JOIN 确保只有与 customer_profile 关联的进行中订单才算"占用"。
        已取消(status=0)或已完成(status=2)的订单对应的编号视为可用。
        CONCAT('A1', '001') = 'A1001' 在 MySQL 中拼接前缀和数字。
        WHERE 子句用 >= 和 <= 做闭区间比较。
    -->
    <select id="findUsedCodesInRange" resultType="java.lang.String">
        SELECT cp.customer_code
        FROM customer_profile cp
        INNER JOIN customer_order co ON co.customer_id = cp.id
        WHERE cp.customer_code LIKE CONCAT(#{poolPrefix}, '%')
          AND cp.customer_code &gt;= CONCAT(#{poolPrefix}, #{poolStart})
          AND cp.customer_code &lt;= CONCAT(#{poolPrefix}, #{poolEnd})
          AND co.status = 1
        ORDER BY cp.customer_code ASC
    </select>

</mapper>
