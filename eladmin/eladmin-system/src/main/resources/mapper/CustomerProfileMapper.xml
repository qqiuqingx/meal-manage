<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="me.zhengjie.modules.customer.profile.mapper.CustomerProfileMapper">

    <resultMap id="BaseResultMap" type="me.zhengjie.modules.customer.profile.domain.CustomerProfile">
        <id column="id" property="id"/>
        <result column="customer_code" property="customerCode"/>
        <result column="customer_name" property="customerName"/>
        <result column="phone" property="phone"/>
        <result column="gestational_week" property="gestationalWeek"/>
        <result column="allergy_tags" property="allergyTags"
                typeHandler="com.baomidou.mybatisplus.extension.handlers.JacksonTypeHandler"/>
        <result column="excluded_dish_ids" property="excludedDishIds"
                typeHandler="com.baomidou.mybatisplus.extension.handlers.JacksonTypeHandler"/>
        <result column="excluded_dates" property="excludedDates"
                typeHandler="me.zhengjie.modules.customer.profile.handler.ExcludedDateListTypeHandler"/>
        <result column="medical_requirements" property="medicalRequirements"/>
        <result column="remark" property="remark"/>
        <result column="create_by" property="createBy"/>
        <result column="update_by" property="updateBy"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <!-- 批量查询客户档案 -->
    <select id="findByIds" resultMap="BaseResultMap">
        SELECT * FROM customer_profile
        WHERE id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </select>

    <!-- 根据ID查询客户档案（带JSON字段反序列化） -->
    <select id="selectByIdWithJson" resultMap="BaseResultMap">
        SELECT * FROM customer_profile WHERE id = #{id}
    </select>

    <!-- 条件查询客户档案列表 -->
    <select id="findAll" resultMap="BaseResultMap">
        SELECT * FROM customer_profile
        <where>
            <if test="criteria.customerCode != null and criteria.customerCode != ''">
                AND customer_code LIKE CONCAT('%', #{criteria.customerCode}, '%')
            </if>
            <if test="criteria.customerName != null and criteria.customerName != ''">
                AND customer_name LIKE CONCAT('%', #{criteria.customerName}, '%')
            </if>
            <if test="criteria.phone != null and criteria.phone != ''">
                AND phone LIKE CONCAT('%', #{criteria.phone}, '%')
            </if>
        </where>
        ORDER BY id DESC
    </select>

    <!-- 根据客户编号查询(排除指定ID) -->
    <select id="countByCodeExcludeId" resultType="int">
        SELECT COUNT(*) FROM customer_profile
        WHERE customer_code = #{customerCode}
        <if test="excludeId != null">
            AND id != #{excludeId}
        </if>
    </select>

</mapper>
